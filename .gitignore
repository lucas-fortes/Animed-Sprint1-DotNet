Add-Content .gitignore @"

# .NET / Visual Studio
.vs/
bin/
obj/
TestResults/
*.user
*.rsuser
*.suo
*.userosscache
*.sln.docstates

# Build outputs
[Bb]uild/
[Dd]ebug/
[Rr]elease/
x64/
x86/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/

# Logs
*.log

# Local databases
*.db
*.sqlite
*.sqlite3
*.db-shm
*.db-wal

# Local environment / secrets
.env
.env.*
appsettings.Development.json
appsettings.Local.json

# Rider / JetBrains
.idea/

# VS Code local settings
.vscode/

# Entity Framework temporary files
efbundle.exe
"@